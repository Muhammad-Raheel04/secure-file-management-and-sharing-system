// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role{
  id Int @id @default(autoincrement())
  name String @unique
  userRoles UserRole[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}


model User{
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  userRoles UserRole[]

  sessions Session[]

  ownedFiles File[] @relation("OwnedFiles")
  uploadedFiles File[] @relation("UploadedFiles")
  filePermissions FilePermission[] @relation("FilePermissionsForUser")
  grantedFilePermissions FilePermission[] @relation("FilePermissionsGrantedBy")

  sharedFiles FileShare[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRole{
  userId Int
  roleId Int

  user User @relation(fields:[userId],references:[id],onDelete:Cascade)

  role Role @relation(fields:[roleId],references:[id],onDelete:Cascade)

  @@id([userId,roleId])
}

model RolePermission{
  roleId Int
  permissionId Int
  
  role Role @relation(fields:[roleId],references:[id],onDelete:Cascade)
  permission Permission @relation(fields:[permissionId],references:[id],onDelete:Cascade)

  @@id([roleId,permissionId])
}

model Session{
  id Int @id @default(autoincrement())
  refreshToken String @unique
  
  userId Int
  user User @relation(fields: [userId],references:[id],onDelete:Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model File{
  id Int @id @default(autoincrement())
  originalName String
  storedName String
  mimeType String
  size Int
  filePath String
  workbook    Workbook?

  categoryId Int
  category FileCategory @relation(fields:[categoryId],references:[id])

  documentTypeId Int
  documentType  DocumentType @relation(fields:[documentTypeId],references:[id])

  ownerId Int
  owner User @relation("OwnedFiles",fields:[ownerId], references: [id], onDelete: Cascade)
  uploadedById Int  
  uploadedBy User @relation("UploadedFiles", fields: [uploadedById], references: [id])
  permissions FilePermission[]

  isDeleted Boolean @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shares FileShare[]

  @@index([ownerId])
  @@index([uploadedById])
  @@index([categoryId])
  @@index([documentTypeId])
}

model FilePermission{
  id Int @id @default(autoincrement())
  fileId Int
  userId Int
  grantedById Int
  fileAccessId Int
  access FileAccess @relation(fields:[fileAccessId],references:[id])

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation("FilePermissionsForUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User @relation("FilePermissionsGrantedBy", fields: [grantedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fileId, userId])
  @@index([fileId])
  @@index([userId])
  @@index([grantedById])
}

model FileCategory{
 id Int @id @default(autoincrement())
 name String @unique

 files File[]

 createdAt DateTime @default(now())
 updatedAt DateTime @default(now())
}

model DocumentType{
 id Int @id @default(autoincrement())
 name String @unique

 files File[]
 createdAt DateTime @default(now())
 updatedAt DateTime @default(now())
}

model Permission{
  id Int @id @default(autoincrement())
  name String @unique

  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FileAccess{
  id Int @id @default(autoincrement())
  name String @unique

  filePermissions FilePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FileShare{
  id Int @id @default(autoincrement())

  token String @unique

  fileId Int
  file File @relation(fields:[fileId],references:[id],onDelete:Cascade)

  sharedById Int
  sharedBy User @relation(fields:[sharedById],references:[id],onDelete:Cascade)

  expiresAt DateTime
  isRevoked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([fileId])
  @@index([expiresAt])
}

model Workbook {
  id              Int          @id @default(autoincrement())
  fileId          Int             @unique
  file            File            @relation(fields: [fileId], references: [id])
  status          WorkbookStatus  @default(PENDING)
  progress        Int             @default(0)
  totalSheets     Int             @default(0)
  processedSheets Int             @default(0)
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  worksheets      Worksheet[]

  @@index([status])
}

enum WorkbookStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Worksheet {
  id          Int   @id @default(autoincrement())
  workbookId  Int
  workbook    Workbook @relation(fields: [workbookId], references: [id],onDelete:Cascade)
  name        String
  sheetIndex  Int      // Preserve worksheet order
  totalRows   Int      @default(0)
  totalColumns Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  columns     WorksheetColumn[]
  rows        WorksheetRow[]

  @@index([workbookId])
  @@unique([workbookId, sheetIndex])
}

model WorksheetColumn {
  id          Int  @id @default(autoincrement())
  worksheetId Int
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id])
  name        String
  columnIndex Int      // Preserve column order
  dataType    String?  // Optional: string, number, date, boolean
  cells WorksheetCell[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([worksheetId])
  @@unique([worksheetId, columnIndex])
}

model WorksheetRow {
  id          Int      @id @default(autoincrement())
  worksheetId Int
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id])
  rowNumber   Int      // Preserve row number
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cells       WorksheetCell[]

  @@index([worksheetId])
  @@unique([worksheetId, rowNumber])
}

model WorksheetCell {
  id          Int   @id @default(autoincrement())
  rowId       Int
  row         WorksheetRow @relation(fields: [rowId], references: [id])
  columnId    Int
  column      WorksheetColumn @relation(fields: [columnId], references: [id])
  value       String?  // Store as string for simplicity
  valueType   String?  // text, number, date, boolean, formula
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([rowId, columnId])
  @@index([rowId])
  @@index([columnId])
  @@index([rowId, columnId])
}
