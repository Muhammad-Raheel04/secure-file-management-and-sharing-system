// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role{
  id Int @id @default(autoincrement())
  name String @unique
  roles User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

enum FileCategory{
  IDENTITY
  EDUCATION
  PROFESSIONAL
  FINANCIAL
  OTHER
}

enum FileAccess{
  READ
  WRITE
}

model User{
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  userRoles Role[]

  sessions Session[]

  ownedFiles File[] @relation("OwnedFiles")
  uploadedFiles File[] @relation("UploadedFiles")
  filePermissions FilePermission[] @relation("FilePermissionsForUser")
  grantedFilePermissions FilePermission[] @relation("FilePermissionsGrantedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session{
  id Int @id @default(autoincrement())
  refreshToken String @unique
  
  userId Int
  user User @relation(fields: [userId],references:[id],onDelete:Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model File{
  id Int @id @default(autoincrement())
  originalName String
  storedName String
  mimeType String
  size Int
  filePath String

  category FileCategory

  documentType String

  ownerId Int
  owner User @relation("OwnedFiles",fields:[ownerId], references: [id], onDelete: Cascade)
  uploadedById Int  
  uploadedBy User @relation("UploadedFiles", fields: [uploadedById], references: [id])
  permissions FilePermission[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([uploadedById])
}

model FilePermission{
  id Int @id @default(autoincrement())
  fileId Int
  userId Int
  grantedById Int
  access FileAccess

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation("FilePermissionsForUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User @relation("FilePermissionsGrantedBy", fields: [grantedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fileId, userId])
  @@index([fileId])
  @@index([userId])
  @@index([grantedById])
}
